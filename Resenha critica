import React, { useState } from "react"; import { Card, CardContent } from "@/components/ui/card"; import { Button } from "@/components/ui/button"; import { Input } from "@/components/ui/input"; import { Textarea } from "@/components/ui/textarea"; import { motion } from "framer-motion";

export default function LavyneaResenhas() { const [reviews, setReviews] = useState([]); const [title, setTitle] = useState(""); const [author, setAuthor] = useState(""); const [content, setContent] = useState(""); const [search, setSearch] = useState("");

const addReview = () => { if (!title || !author || !content) return; const newReview = { id: Date.now(), title, author, content, date: new Date().toLocaleDateString() }; setReviews([newReview, ...reviews]); setTitle(""); setAuthor(""); setContent(""); };

const filteredReviews = reviews.filter((review) => review.title.toLowerCase().includes(search.toLowerCase()) );

return ( <div className="min-h-screen bg-gray-100 p-6"> <div className="max-w-4xl mx-auto"> <motion.h1 initial={{ opacity: 0, y: -20 }} animate={{ opacity: 1, y: 0 }} className="text-3xl font-bold text-center mb-6" > 📚 Resenhas Críticas da Lavynea </motion.h1>

<Card className="mb-6 p-4 shadow-lg rounded-2xl">
      <CardContent className="space-y-4">
        <Input
          placeholder="Título do livro"
          value={title}
          onChange={(e) => setTitle(e.target.value)}
        />
        <Input
          placeholder="Autor"
          value={author}
          onChange={(e) => setAuthor(e.target.value)}
        />
        <Textarea
          placeholder="Escreva sua resenha crítica aqui..."
          value={content}
          onChange={(e) => setContent(e.target.value)}
          className="min-h-[120px]"
        />
        <Button onClick={addReview} className="w-full rounded-2xl">
          Publicar Resenha
        </Button>
      </CardContent>
    </Card>

    <div className="mb-4">
      <Input
        placeholder="Pesquisar por título..."
        value={search}
        onChange={(e) => setSearch(e.target.value)}
      />
    </div>

    <div className="grid gap-4">
      {filteredReviews.map((review) => (
        <motion.div
          key={review.id}
          initial={{ opacity: 0 }}
          animate={{ opacity: 1 }}
        >
          <Card className="shadow-md rounded-2xl">
            <CardContent className="p-4">
              <h2 className="text-xl font-semibold">{review.title}</h2>
              <p className="text-sm text-gray-500">Autor: {review.author}</p>
              <p className="text-xs text-gray-400 mb-2">Publicado em {review.date}</p>
              <p className="text-base">{review.content}</p>
            </CardContent>
          </Card>
        </motion.div>
      ))}
    </div>
  </div>
</div>

); }
